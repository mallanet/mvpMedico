# === Required for Vercel / production ===
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — never expose to the browser / never commit real values
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Canonical public URL (no trailing slash).
NEXT_PUBLIC_APP_URL=https://YOUR_APP.vercel.app

# === Optional ===
NEXT_PUBLIC_MALLANET_DONATION_URL=https://mallanet.example/donate
# Email notifications (Resend). Without these, notify is a no-op (logs in dev).
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=Waira <onboarding@resend.dev>

# === Demo mode (no backend) ===
# Omit NEXT_PUBLIC_SUPABASE_* entirely, or set:
# NEXT_PUBLIC_SUPABASE_URL=mock
# NEXT_PUBLIC_SUPABASE_ANON_KEY=mock
# → auth, calendar, landings y membresías usan seed local (ver specs/002-full-demo-seed)

# === Local overrides (copy to .env.local) ===
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Playwright (optional — smoke tests run without these)
# E2E_DOCTOR_EMAIL=doctor@example.com
# E2E_DOCTOR_PASSWORD=password123
# E2E_LANDING_SLUG=dra-reyes
# E2E_ADMIN_EMAIL=admin@example.com
# E2E_ADMIN_PASSWORD=password123
# E2E_FULL_APPOINTMENTS=1
