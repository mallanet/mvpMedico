# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — never expose to the browser / never commit real values
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional CTA on public landings (Mallanet donations hub — link-out only)
NEXT_PUBLIC_MALLANET_DONATION_URL=https://mallanet.example/donate

# Google Calendar OAuth (busy → block). Leave empty for local UI without Google.
# Routes return 501 with a clear message when unset.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# Playwright (optional — smoke tests run without these)
# E2E_DOCTOR_EMAIL=doctor@example.com
# E2E_DOCTOR_PASSWORD=password123
# E2E_LANDING_SLUG=dra-demo
# E2E_ADMIN_EMAIL=admin@example.com
# E2E_ADMIN_PASSWORD=password123
# E2E_FULL_APPOINTMENTS=1
# E2E_FULL_BOOKING=1
# E2E_FULL_ADMIN=1
